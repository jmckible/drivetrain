[alias]
	co = checkout
	br = branch
	ci = commit
	st = status
[pull]
	rebase = true
[init]
	defaultBranch = master
[user]
	name = Jordan McKible
	email = jordan@mckible.com
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
[push]
	autoSetupRemote = true
[fetch]
	prune = true
[includeIf "gitdir:~/dev/vocal*/"]
	path = ~/.config/git/config-vocal
