#!/bin/bash

# Manage the desktop's light/dark color mode.
#
# Always flips the GNOME color-scheme preference (prefer-light/prefer-dark) so
# any portal-aware app follows the chosen mode. On the drivetrain theme, also
# overrides Helium's chromium policy color to white via the theme-set hook (see
# hooks/theme-set), since drivetrain is natively dark but its backgrounds rotate
# through light periods. On other Omarchy themes the helium override is a no-op
# (the theme's intrinsic color stands); only the portal color-scheme changes.
#
# Subcommands:
#   status     Waybar JSON ({text, tooltip, class}) for the current mode.
#   pick       Walker dmenu picker — choose Light or Dark (drivetrain only).
#   set MODE   Force MODE (light|dark) and re-apply.
#   toggle     Flip light/dark (drivetrain only).

FLAG="$HOME/.config/helium-force-light"
HOOK="$HOME/.config/omarchy/hooks/theme-set"
WAYBAR_SIGNAL=12

current_theme() {
    cat "$HOME/.config/omarchy/current/theme.name" 2>/dev/null
}

is_drivetrain() {
    [[ "$(current_theme)" == "drivetrain" ]]
}

effective_mode() {
    if is_drivetrain && [[ -f "$FLAG" ]]; then
        echo "light"
    else
        echo "dark"
    fi
}

refresh_helium() {
    pgrep -x helium-browser >/dev/null 2>&1 || return
    helium-browser --refresh-platform-policy --no-startup-window &>/dev/null &
}

# Flip the desktop color-scheme preference. Helium (and any other portal-aware
# app) reads this via xdg-desktop-portal when its theme is set to "Device", so
# without this the browser stays dark even though we override the toolbar tint.
set_color_scheme() {
    local scheme="$1"  # prefer-light | prefer-dark
    gsettings set org.gnome.desktop.interface color-scheme "$scheme" 2>/dev/null
}

signal_waybar() {
    pkill -RTMIN+$WAYBAR_SIGNAL waybar 2>/dev/null
}

apply() {
    # Re-derive Omarchy's natural color, then let the hook override if needed.
    omarchy-theme-set-browser
    "$HOOK"
    if [[ "$(effective_mode)" == "light" ]]; then
        set_color_scheme prefer-light
    else
        set_color_scheme prefer-dark
    fi
    refresh_helium
    signal_waybar
}

cmd_status() {
    local mode icon tooltip class
    mode=$(effective_mode)
    if [[ "$mode" == "light" ]]; then
        icon="󰛨"
        class="light"
    else
        icon="󰹒"
        class="dark"
    fi
    if is_drivetrain; then
        tooltip="Color mode: ${mode^}\nTheme: drivetrain\nClick to switch"
    else
        tooltip="Color mode: ${mode^}\nTheme: $(current_theme) (light override only applies on drivetrain)"
    fi
    printf '{"text": "%s", "tooltip": "%s", "class": "%s"}\n' "$icon" "$tooltip" "$class"
}

cmd_pick() {
    if ! is_drivetrain; then
        notify-send -u low "Color mode" "Light override only applies on drivetrain. Current theme: $(current_theme)"
        return
    fi
    local options="󰛨  Light"$'\n'"󰹒  Dark"
    local choice
    choice=$(echo -e "$options" | omarchy-launch-walker --dmenu --width 220 --minheight 1 --maxheight 200 -p "Color mode…" 2>/dev/null)
    [[ -z "$choice" ]] && return
    case "${choice##* }" in
        Light) cmd_set light ;;
        Dark)  cmd_set dark ;;
    esac
}

cmd_set() {
    case "$1" in
        light) touch "$FLAG" ;;
        dark)  rm -f "$FLAG" ;;
        *) echo "usage: color-mode set {light|dark}" >&2; exit 1 ;;
    esac
    apply
}

cmd_toggle() {
    if [[ "$(effective_mode)" == "light" ]]; then
        cmd_set dark
    else
        cmd_set light
    fi
}

case "${1:-status}" in
    status) cmd_status ;;
    pick)   cmd_pick ;;
    set)    shift; cmd_set "$@" ;;
    toggle) cmd_toggle ;;
    *) echo "usage: color-mode {status|pick|set MODE|toggle}" >&2; exit 1 ;;
esac
