#!/bin/bash
cd ~/dev/drivetrain/openclaw

case "$1" in
  up)
    shift
    op run --env-file=.env.tpl -- docker compose up -d openclaw-gateway "$@"
    ;;
  restart)
    op run --env-file=.env.tpl -- docker compose restart openclaw-gateway
    ;;
  update)
    op run --env-file=.env.tpl -- docker compose pull openclaw-gateway
    op run --env-file=.env.tpl -- docker compose up -d openclaw-gateway
    ;;
  *)
    op run --env-file=.env.tpl -- docker compose "$@"
    ;;
esac
